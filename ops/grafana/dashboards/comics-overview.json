{
  "id": null,
  "uid": "comics-overview",
  "title": "Comics Backend Overview",
  "tags": [
    "spring",
    "micrometer"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Total RPS",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Rate %",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_server_requests_seconds_count[1m])) * 100",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p99 Latency",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Heap Used %",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / sum(jvm_memory_max_bytes{area=\"heap\"}) * 100",
          "legendFormat": "Heap %"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests/sec",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx rate",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 4xx rate",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..\"}[1m])) or vector(0)",
          "legendFormat": "4xx/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPS by Endpoint",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (uri, method)",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "p50 / p95 / p99 Latency (global)",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency by Endpoint",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, uri, method))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "JVM Memory",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Non-Heap (Metaspace etc.)",
      "gridPos": {
        "x": 12,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "JVM GC & Threads",
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "GC Pause — avg duration (sec)",
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[1m]) / rate(jvm_gc_pause_seconds_count[1m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC Collections/sec",
      "gridPos": {
        "x": 12,
        "y": 40,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count[1m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Live Threads",
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "live"
        },
        {
          "expr": "jvm_threads_daemon_threads",
          "legendFormat": "daemon"
        },
        {
          "expr": "jvm_threads_peak_threads",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Thread States",
      "gridPos": {
        "x": 12,
        "y": 48,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "jvm_threads_states_threads",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "CPU & Process",
      "gridPos": {
        "x": 0,
        "y": 56,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": {
        "x": 0,
        "y": 57,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "process"
        },
        {
          "expr": "system_cpu_usage",
          "legendFormat": "system"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Open File Descriptors",
      "gridPos": {
        "x": 12,
        "y": 57,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "process_files_open_files",
          "legendFormat": "open"
        },
        {
          "expr": "process_files_max_files",
          "legendFormat": "max"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": {
        "x": 20,
        "y": 57,
        "w": 4,
        "h": 8
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "process_uptime_seconds",
          "legendFormat": "uptime"
        }
      ]
    },
    {
      "type": "row",
      "title": "HikariCP Connection Pool",
      "gridPos": {
        "x": 0,
        "y": 65,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "DB Connections",
      "gridPos": {
        "x": 0,
        "y": 66,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "idle"
        },
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending"
        },
        {
          "expr": "hikaricp_connections_max",
          "legendFormat": "max"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connection Acquisition Time p95 (sec)",
      "gridPos": {
        "x": 12,
        "y": 66,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(hikaricp_connections_acquire_seconds_bucket[1m])) by (le, pool))",
          "legendFormat": "{{pool}} p95"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cache",
      "gridPos": {
        "x": 0,
        "y": 74,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": {
        "x": 0,
        "y": 75,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cache_gets_total{result=\"hit\"}[1m])) by (name) / sum(rate(cache_gets_total[1m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Evictions/sec",
      "gridPos": {
        "x": 12,
        "y": 75,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(cache_evictions_total[1m]) or vector(0)",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ]
}