COMPOSE_PROJECT_NAME=uni-diploma

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=comics-db
POSTGRES_USERNAME=myuser
POSTGRES_PASSWORD=secret

# MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USERNAME=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Keycloak
KEYCLOAK_PORT=8081
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KEYCLOAK_DB=postgres
KEYCLOAK_DB_USERNAME=myuser
KEYCLOAK_DB_PASSWORD=secret
