COMPOSE_PROJECT_NAME=harakki-comics-backend

# Backend Launch Config (local developement)
SPRING_PROFILES_ACTIVE=dev
JAVA_TOOL_OPTIONS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005

# Backend
BACKEND_PORT=8080
BACKEND_DB_URL=jdbc:postgresql://postgres:5432/comics-db
BACKEND_S3_INTERNAL_ENDPOINT=http://minio:9000
BACKEND_S3_EXTERNAL_ENDPOINT=http://s3.localhost:80
BACKEND_S3_BUCKET_NAME=comics-bucket
BACKEND_JWT_ISSUER_URI=http://keycloak:8080/realms/comics
BACKEND_JWT_JWK_SET_URI=http://keycloak:8080/realms/comics/protocol/openid-connect/certs

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=comics-db
POSTGRES_USERNAME=myuser
POSTGRES_PASSWORD=secret

# MinIO
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USERNAME=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Keycloak
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KEYCLOAK_DB=postgres
KEYCLOAK_DB_USERNAME=myuser
KEYCLOAK_DB_PASSWORD=secret
